# DeepSeek API 密钥（必填）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ============ 和风天气 ============
# 控制台：https://console.qweather.com

# API Host（控制台 → 项目 → API Host，形如 xxx.qweatherapi.com）
QWEATHER_HOST=your_qweather_host_here

# JWT token（鉴权用）。两种获取方式：
#   1. 控制台「设置 → 凭证」直接生成 token，粘贴到这里
#   2. 用 scripts/gen_qweather_jwt.py 本地签发（需配下面三个变量），把生成的 token 填这里
QWEATHER_KEY=your_qweather_jwt_token_here

# --- 以下仅在用 scripts/gen_qweather_jwt.py 本地签发 token 时需要 ---
# 在控制台「设置 → 凭证」获取
QWEATHER_PROJECT_ID=your_project_id_here
QWEATHER_CREDENTIAL_ID=your_credential_id_here
# Ed25519 私钥文件路径（PEM 格式，从控制台 Key 保存为 .pem 文件；*.pem 已被 .gitignore 忽略）
QWEATHER_PRIVATE_KEY_FILE=path/to/your_ed25519.pem
